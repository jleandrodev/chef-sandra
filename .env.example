# ───── Chef Sandra — variáveis de ambiente ─────
# Copie este arquivo para .env e preencha os valores.
# .env NUNCA é commitado (está no .gitignore).

AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Hotmart / Stripe checkout URLs
CHECKOUT_MAIN=
CHECKOUT_BASIC=
CHECKOUT_PREMIUM=

# Trigger phrase que ativa o agente
TRIGGER=
